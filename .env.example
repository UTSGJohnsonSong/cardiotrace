# Copy this file to .env and adjust if needed.
# .env is gitignored — never commit credentials.

# Default points at the Dockerized Postgres from docker-compose.yml
# (host port 5435 to avoid clashing with a local 5432 install).
DATABASE_URL=postgresql://cardiotrace:cardiotrace@localhost:5435/cardiotrace

# If you use your own local PostgreSQL instead of Docker:
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/cardiotrace
